# =============================================================================
# FreshPass Environment Variables
# Copy this file to .env and fill in the values.
# Ask the FreshPass team for actual credentials.
# =============================================================================

# --- API & Authentication (Required) ---
EXPO_PUBLIC_API_BASE_URL=https://your-api-url.com
EXPO_PUBLIC_AUTH_TOKEN=your-guest-auth-token

# --- Stripe Payments (Required) ---
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# --- Google Services (Required for maps & social login) ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_SEARCH_URL=https://maps.googleapis.com/maps/api/place/autocomplete/json
EXPO_PUBLIC_GOOGLE_FETCH_PLACE_URL=https://maps.googleapis.com/maps/api/place/details/json

# --- Social Login (Optional) ---
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=
EXPO_PUBLIC_APPLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_APPLE_ANDROID_REDIRECT_URI=

# --- Real-time Chat / Laravel Reverb (Required for chat) ---
EXPO_PUBLIC_REVERB_APP_KEY=your-reverb-app-key
EXPO_PUBLIC_REVERB_WS_HOST=
EXPO_PUBLIC_REVERB_WS_PORT=
EXPO_PUBLIC_REVERB_SCHEME=

# --- AI Features (Optional) ---
EXPO_PUBLIC_AITOOL_API_BASE_URL=
EXPO_PUBLIC_AI_API_BEARER_TOKEN=
EXPO_PUBLIC_WEBHOOK_URL=
EXPO_PUBLIC_TUTORIAL_VIDEO_TRYON_URI=

# --- Apple In-App Purchase (iOS only) ---
EXPO_PUBLIC_IAP_BUSINESS_PLAN_STANDARD_PRODUCT_ID=com.freshpass.business.plan.21
EXPO_PUBLIC_IAP_BUSINESS_PLAN_FEATURED_PRODUCT_ID=com.freshpass.business.plan.21.featured
EXPO_PUBLIC_IAP_BUSINESS_PLAN_PREFIX=com.freshpass.business.plan
EXPO_PUBLIC_IAP_AI_SERVICE_PREFIX=com.freshpass.ai.service

# --- Default Images & URLs (Optional) ---
EXPO_PUBLIC_DEFAULT_AVATAR_IMAGE=
EXPO_PUBLIC_DEFAULT_BUSINESS_IMAGE=
EXPO_PUBLIC_DEFAULT_BUSINESS_LOGO=
EXPO_PUBLIC_DEFAULT_CATEGORY_IMAGE=
EXPO_PUBLIC_DEFAULT_AI_REQUESTS_IMAGE=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
EXPO_PUBLIC_TRAILDAY=14
